    "UserCodesTable": "VibraHeka-users-codes-default",
    "PasswordResetTokenSecret": "test-only-change-this-secret-to-a-long-random-value",
    "EmailTemplatesTable": "VibraHeka-EmailTempaltes-test",
    "ClientId": "5poiphp43irgl07obv2fttifl1",
    "UserPoolId": "eu-west-1_Uz8CCr1KJ",
    "ActionLogTable": "VibraHeka-action-log-test",
    "SubscriptionTable": "VibraHeka-subscriptions-test",
    "SubscriptionUserIdIndex": "User-Index",
    "Location": "eu-west-1",
    "SettingsNameSpace": "VibraHeka"
  },
  "Settings": {
    "UseSerilog": true
  },
  "XRay": {
    "DaemonAddress": "127.0.0.1:2000",
    "ServiceName": "VibraHeka"
  },
  "AWSLogging": {
    "LogGroup": "/my-app/logs",
    "Region": "eu-west-1",
    "Profile": "Twingers",
    "IncludeScopes": true,
    "LogLevel": {
      "Default": "Information"
    }
  },
  "Stripe": {
    "SecretKey": "",
    "PaymentSuccessUrl": "http://localhost:5173/profile/me",
    "PaymentCancelUrl": "http://localhost:5173/profile/me",
    "PaymentMethodsAccepted": [
      "card"
    ],
    "TrialPeriodInDays": 14,
    "SubscriptionId": "price_1SyxN98p2opQAPTX1XXPGLIA"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "VibraHeka": "Debug",
      "Microsoft.AspNetCore.SpaProxy": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning"
      }
    },
    "Enrich": [
      "FromLogContext",
      "WithXRayEnricher"
    ],
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{SourceContext}] [{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "AmazonCloudWatch",
        "Args": {
          "logGroupName": "/my-app/logs",
          "batchSizeLimit": 100,
          "createLogGroup": true,
          "period": "00:00:01",
          "formatter": "Serilog.Formatting.Compact.RenderedCompactJsonFormatter, Serilog.Formatting.Compact"
        }
      }
    ]
  },
  "Backend": {
  }
}
