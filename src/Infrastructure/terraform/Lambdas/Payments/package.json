{
  "name": "stripe-lambda",
  "version": "1.0.0",
  "description": "Lambda to receive updates from Stripe",
  "main": "index.js",
  "type": "commonjs",
  "scripts": {
    "test": "tsx test-local.ts",
    "build": "esbuild ./src/lambda_stripe.ts --bundle --platform=node --target=node20 --outdir=dist",
    "lint": "eslint ./src/**/*.{ts,tsx} --fix",
    "zip": "cd dist && zip -r ../lambda.zip . && cd ..",
    "zip:windows": "powershell -Command \"Compress-Archive -Path dist\\* -DestinationPath lambda.zip -Force\"",
    "run:local": "npm run build && sam build && sam local start-api",
    "e2e:build": "npm run build && sam build",
    "e2e:sam": "npm run e2e:build && sam local start-api",
    "e2e:stripe-listen": "stripe listen --events checkout.session.completed,invoice.paid,invoice.payment_failed,customer.subscription.trial_will_end,customer.subscription.updated,customer.subscription.deleted --forward-to localhost:3000/webhook",
    "test:e2e": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --runInBand test/E2E",
    "test:integration": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --runInBand test/Integration",
    "e2e:full": "powershell -ExecutionPolicy Bypass -File ./scripts/run-e2e.ps1"
  },
  "author": "Twingers Corporation",
  "license": "ISC",
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.3",
    "@types/aws-lambda": "^8.10.147",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.13.5",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "aws-sdk-client-mock": "^4.1.0",
    "dotenv": "^17.3.1",
    "esbuild": "^0.25.0",
    "eslint": "^10.0.0",
    "fs": "0.0.1-security",
    "jest": "^30.2.0",
    "jest-mock-extended": "^4.0.0",
    "path": "^0.12.7",
    "prettier-plugin-organize-imports": "^4.3.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "uuid": "^13.0.0"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.991.0",
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/client-ses": "^3.980.0",
    "@aws-sdk/client-ssm": "^3.700.0",
    "@aws-sdk/credential-providers": "^3.991.0",
    "@aws-sdk/util-dynamodb": "^3.991.0",
    "neverthrow": "^8.2.0",
    "stripe": "^20.3.1"
  }
}
