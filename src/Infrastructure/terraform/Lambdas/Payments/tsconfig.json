{
  "compilerOptions": {
    "target": "es2020",
    "module": "NodeNext",
    "baseUrl": "./",     
    "isolatedModules": true,
     "paths": {          
       "@/*": ["src/*"],
       "@Domain/*": ["src/Domain/*"],
       "@Data/*": ["src/Data/*"],
       "@Application/*": ["src/Application/*"]
     },
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts"]
}
